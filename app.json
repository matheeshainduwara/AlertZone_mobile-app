{
  "expo": {
    "name": "AlertZone",
    "slug": "alertzone",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/iconAlerZone.png",
    "scheme": "mobileapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "config": {
        "googleMapsApiKey": "AIzaSyC43kjBIm6oio6od630NQbjVw9x-f2xp5Q"
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0D1E2C",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyC43kjBIm6oio6od630NQbjVw9x-f2xp5Q"
        }
      },
      "package": "com.anonymous.alertzone",
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow AlertZone to use your location to show nearby issues."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#122D36",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "55db983e-26bb-4c43-891e-d4e1155bd5ec"
      }
    },
    "owner": "stjalthotage"
  }
}
