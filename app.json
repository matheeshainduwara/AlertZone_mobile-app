{
  "expo": {
    "name": "AlertZone",
    "slug": "alertzone",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/AppIcon.png",
    "scheme": "mobileapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "config": {
        "googleMapsApiKey": "AIzaSyC43kjBIm6oio6od630NQbjVw9x-f2xp5Q"
      },
      "infoPlist": {
        "NSFaceIDUsageDescription": "Allow AlertZone to use Face ID for fast login."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0D1E2C",
        "foregroundImage": "./assets/images/AppIcon.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyC43kjBIm6oio6od630NQbjVw9x-f2xp5Q"
        }
      },
      "package": "com.anonymous.alertzone",
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/android-icon-monochrome.png",
          "color": "#30A89C",
          "defaultChannel": "alertzone-alerts",
          "sounds": []
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow AlertZone to use your location to show nearby issues."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/iconAlerZone-Bg-none.png",
          "imageWidth": 180,
          "resizeMode": "contain",
          "backgroundColor": "#0D1F2D",
          "dark": {
            "image": "./assets/images/iconAlerZone-Bg-none.png",
            "imageWidth": 180,
            "resizeMode": "contain",
            "backgroundColor": "#0D1F2D"
          }
        }
      ],
      "expo-web-browser",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "55db983e-26bb-4c43-891e-d4e1155bd5ec"
      }
    },
    "owner": "stjalthotage"
  }
}
